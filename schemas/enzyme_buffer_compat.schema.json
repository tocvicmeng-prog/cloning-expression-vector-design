{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV enzyme buffer compatibility matrix",
  "type": "object",
  "required": ["catalogue_id", "schema_version", "maintenance", "buffers", "compatibility"],
  "properties": {
    "catalogue_id": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "minLength": 1},
    "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]},
    "buffers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "buffer_class", "citation", "maintenance"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "buffer_class": {"type": "string", "minLength": 1},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]},
          "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]}
        }
      }
    },
    "compatibility": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["buffer_id", "enzyme_ids", "compatibility", "citation", "maintenance"],
        "properties": {
          "buffer_id": {"type": "string", "minLength": 1},
          "enzyme_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "compatibility": {"type": "string", "minLength": 1},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]},
          "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]}
        }
      }
    }
  }
}
