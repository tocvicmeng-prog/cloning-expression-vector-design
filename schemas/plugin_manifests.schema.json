{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV plugin manifests",
  "type": "object",
  "required": ["maintenance", "manifests"],
  "properties": {
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]
    },
    "manifests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "version",
          "artefact_path",
          "artefact_sha256",
          "permissions",
          "signature",
          "citation"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "artefact_path": {"type": "string", "minLength": 1},
          "artefact_sha256": {"type": "string", "minLength": 64},
          "permissions": {
            "type": "object",
            "required": ["file_access", "network_access", "deterministic_paths"],
            "properties": {
              "file_access": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "network_access": {"type": "boolean"},
              "deterministic_paths": {"type": "boolean"},
              "network_hosts": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          },
          "signature": {
            "type": "object",
            "required": ["key_id", "algorithm", "signed_payload_hash", "signature"],
            "properties": {
              "key_id": {"type": "string", "minLength": 1},
              "algorithm": {"type": "string", "enum": ["ed25519"]},
              "signed_payload_hash": {"type": "string", "minLength": 64},
              "signature": {"type": "string", "minLength": 1}
            }
          },
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]}
        }
      }
    }
  }
}
