{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV plugin manifests",
  "type": "object",
  "required": ["maintenance", "manifests"],
  "properties": {
    "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]},
    "manifests": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "name", "version", "citation"], "properties": {"id": {"type": "string", "minLength": 1}, "name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "citation": {"type": "object", "required": ["text", "grade", "accessed"]}}}}
  }
}
