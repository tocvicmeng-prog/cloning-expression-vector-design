{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV institutional policy",
  "type": "object",
  "required": ["maintenance", "policy_set_id", "policy_version", "defaults", "authorization_profiles", "citations"],
  "properties": {
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]
    },
    "policy_set_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "minLength": 1},
    "defaults": {
      "type": "object",
      "required": [
        "administrator_controlled_authorisation",
        "user_self_authorisation_allowed",
        "unsupported_biosafety_tiers",
        "require_screening_before_sop",
        "require_active_advisory_acknowledgement"
      ]
    },
    "dual_control_defaults": {"type": "object"},
    "authorization_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "allowed_biosafety_tiers", "citation"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "allowed_biosafety_tiers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]}
        }
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object", "required": ["text", "grade", "accessed"]}
    }
  }
}
