{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV hosts catalogue",
  "type": "object",
  "required": ["catalogue_id", "schema_version", "maintenance", "items"],
  "properties": {
    "catalogue_id": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "minLength": 1},
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"],
      "properties": {
        "retrieved_at": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date"},
        "source_url": {"type": "string", "minLength": 1},
        "review_required_after": {"type": "string", "format": "date"}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "chassis_class",
          "source_section",
          "host_roles",
          "genotype",
          "supplier_reference",
          "replicons_supported",
          "expression_features",
          "codon_usage_table_id",
          "growth_conditions",
          "biosafety_tier",
          "citation",
          "maintenance"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "chassis_class": {"type": "string", "minLength": 1},
          "source_section": {"type": "string", "minLength": 1},
          "host_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "genotype": {"type": "string", "minLength": 1},
          "supplier_reference": {"type": "string", "minLength": 1},
          "replicons_supported": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "expression_features": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "codon_usage_table_id": {"type": "string", "minLength": 1},
          "growth_conditions": {"type": "string", "minLength": 1},
          "biosafety_tier": {"type": "string", "enum": ["BSL-1", "BSL-2", "BSL-2+", "BSL-3", "BSL-4"]},
          "citation": {
            "type": "object",
            "required": ["text", "grade", "accessed"],
            "properties": {
              "text": {"type": "string", "minLength": 1},
              "grade": {"type": "string", "enum": ["A1", "A2", "A3", "B1", "B2", "C"]},
              "accessed": {"type": "string", "format": "date"}
            }
          },
          "maintenance": {
            "type": "object",
            "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"],
            "properties": {
              "retrieved_at": {"type": "string", "format": "date"},
              "valid_until": {"type": "string", "format": "date"},
              "source_url": {"type": "string", "minLength": 1},
              "review_required_after": {"type": "string", "format": "date"}
            }
          }
        }
      }
    }
  }
}
