{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV enzymes catalogue",
  "type": "object",
  "required": ["catalogue_id", "schema_version", "maintenance", "items"],
  "properties": {
    "catalogue_id": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "minLength": 1},
    "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "enzyme_class", "recognition_site", "cut_offset", "overhang", "methylation_sensitivity", "use_cases", "supplier_reference", "citation", "maintenance"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "enzyme_class": {"type": "string", "minLength": 1},
          "recognition_site": {"type": "string", "minLength": 1},
          "cut_offset": {"type": "string", "minLength": 1},
          "overhang": {"type": "string", "minLength": 1},
          "methylation_sensitivity": {"type": "string", "minLength": 1},
          "use_cases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "supplier_reference": {"type": "string", "minLength": 1},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]},
          "maintenance": {"type": "object", "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]}
        }
      }
    }
  }
}
