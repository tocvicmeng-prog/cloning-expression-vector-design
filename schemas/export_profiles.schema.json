{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV export profiles",
  "type": "object",
  "required": ["maintenance", "profile_set_id", "profile_version", "profiles", "citations"],
  "properties": {
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]
    },
    "profile_set_id": {"type": "string", "minLength": 1},
    "profile_version": {"type": "string", "minLength": 1},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "redaction_level", "intended_recipient", "include_sequences", "citation"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "redaction_level": {"type": "string", "minLength": 1},
          "intended_recipient": {"type": "string", "minLength": 1},
          "include_sequences": {"type": "boolean"},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]}
        }
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object", "required": ["text", "grade", "accessed"]}
    }
  }
}
