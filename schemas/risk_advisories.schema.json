{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV risk advisories",
  "type": "object",
  "required": ["maintenance", "advisory_set_id", "advisory_version", "acknowledgement_policy", "advisories", "citations"],
  "properties": {
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]
    },
    "advisory_set_id": {"type": "string", "minLength": 1},
    "advisory_version": {"type": "string", "minLength": 1},
    "acknowledgement_policy": {"type": "object"},
    "advisories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "severity", "trigger_tags", "recommended_action", "blocks", "citation"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["info", "caution", "strong_caution"]},
          "trigger_tags": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "recommended_action": {"type": "string", "minLength": 1},
          "blocks": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "citation": {"type": "object", "required": ["text", "grade", "accessed"]}
        }
      }
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object", "required": ["text", "grade", "accessed"]}
    }
  }
}
