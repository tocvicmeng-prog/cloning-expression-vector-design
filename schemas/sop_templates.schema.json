{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEV SOP templates",
  "type": "object",
  "required": ["maintenance", "templates"],
  "properties": {
    "maintenance": {
      "type": "object",
      "required": ["retrieved_at", "valid_until", "source_url", "review_required_after"]
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "version",
          "description",
          "content_markdown",
          "hazard_notes",
          "required_approval_gate",
          "citation"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "content_markdown": {"type": "string", "minLength": 1},
          "hazard_notes": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "required_approval_gate": {"type": "string", "minLength": 1},
          "citation": {
            "type": "object",
            "required": ["text", "grade", "accessed"],
            "properties": {
              "text": {"type": "string", "minLength": 1},
              "grade": {"type": "string", "minLength": 1},
              "accessed": {"type": "string", "minLength": 1},
              "url": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
