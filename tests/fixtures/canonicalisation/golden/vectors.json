[
  {"name": "empty-object", "input": {}, "expected": "{}"},
  {"name": "empty-array", "input": [], "expected": "[]"},
  {"name": "null", "input": null, "expected": "null"},
  {"name": "booleans", "input": [true, false], "expected": "[true,false]"},
  {"name": "ascii-key-order", "input": {"b": 2, "a": 1}, "expected": "{\"a\":1,\"b\":2}"},
  {"name": "nfc-string", "input": "é", "expected": "\"é\""},
  {"name": "control-characters", "input": "line\n\tend", "expected": "\"line\\n\\tend\""},
  {"name": "nested-object-order", "input": {"z": {"b": 2, "a": 1}, "a": [3, 2, 1]}, "expected": "{\"a\":[3,2,1],\"z\":{\"a\":1,\"b\":2}}"},
  {"name": "utf16-key-order", "input": {"": 2, "😀": 1}, "expected": "{\"😀\":1,\"\":2}"},
  {"name": "array-order-preserved", "input": [{"b": 2, "a": 1}, {"d": 4, "c": 3}], "expected": "[{\"a\":1,\"b\":2},{\"c\":3,\"d\":4}]"},
  {"name": "decimal-zero", "input": {"__decimal__": "0.000"}, "expected": "{\"$$cev:decimal\":\"0\"}"},
  {"name": "decimal-trailing-zeroes", "input": {"__decimal__": "12.3400"}, "expected": "{\"$$cev:decimal\":\"12.34\"}"},
  {"name": "decimal-exponent", "input": {"__decimal__": "1.2300E+3"}, "expected": "{\"$$cev:decimal\":\"1230\"}"},
  {"name": "legacy-decimal-tag", "input": {"__legacy_decimal__": "12.3450"}, "expected": "{\"$$cev:decimal\":\"12.345\"}"},
  {"name": "datetime-utc", "input": {"__datetime__": "2026-05-14T10:30:00.123456+00:00"}, "expected": "{\"$$cev:datetime\":\"2026-05-14T10:30:00.123456Z\"}"},
  {"name": "datetime-offset", "input": {"__datetime__": "2026-05-14T20:00:00.000001+09:30"}, "expected": "{\"$$cev:datetime\":\"2026-05-14T10:30:00.000001Z\"}"},
  {"name": "bytes", "input": {"__bytes__": "AAE="}, "expected": "{\"$$cev:bytes\":\"AAE=\"}"},
  {"name": "float-integer", "input": 1.0, "expected": "1"},
  {"name": "negative-zero", "input": -0.0, "expected": "0"},
  {"name": "float-decimal-threshold-high", "input": 1e20, "expected": "100000000000000000000"},
  {"name": "float-exponent-threshold-high", "input": 1e21, "expected": "1e+21"},
  {"name": "float-decimal-threshold-low", "input": 1e-6, "expected": "0.000001"},
  {"name": "float-exponent-threshold-low", "input": 1e-7, "expected": "1e-7"},
  {"name": "float-rounding", "input": 333333333.33333329, "expected": "333333333.3333333"},
  {"name": "float-trailing-zero", "input": 4.50, "expected": "4.5"},
  {"name": "deeply-nested", "input": {"outer": {"middle": {"inner": [{"b": false, "a": true}]}}}, "expected": "{\"outer\":{\"middle\":{\"inner\":[{\"a\":true,\"b\":false}]}}}"},
  {"name": "slash-unescaped", "input": "a/b", "expected": "\"a/b\""},
  {"name": "quote-and-backslash", "input": "\"\\", "expected": "\"\\\"\\\\\""},
  {"name": "mixed-list", "input": ["x", 2, null, {"b": false, "a": true}], "expected": "[\"x\",2,null,{\"a\":true,\"b\":false}]"},
  {"name": "line-separator", "input": " ", "expected": "\" \""},
  {"name": "negative-float", "input": -12.3400, "expected": "-12.34"},
  {"name": "max-safe-integer", "input": 9007199254740991, "expected": "9007199254740991"}
]
